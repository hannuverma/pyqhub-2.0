generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String
  email     String   @unique
  password  String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("express_users")
}

model Paper {
  id          Int      @id @default(autoincrement())
  title       String
  semester    Int
  year        Int
  examType    String
  batch       String   @default("IT")
  pdf         String
  pdfPublicId String
  uploadedAt  DateTime @default(now())

  @@map("express_papers")
}
